{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "maxNodeModuleJsDepth": 0,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "scripts/**/*.mjs",
    "src/router/editorRouteState.js",
    "src/router/routePaths.js",
    "src/router/routes.js",
    "worker/**/*.js"
  ],
  "exclude": ["node_modules", "dist"]
}
