{
  "name": "pdf-editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/generate-tool-sitemap.mjs && vite build && node scripts/prerender-public-routes.mjs && node scripts/prepare-sites-build.mjs",
    "audit:seo": "npm run build && node scripts/audit-seo.mjs",
    "audit:quality": "node scripts/audit-product-quality.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "typecheck": "tsc --project jsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run build && node --test tests/e2e/*.test.mjs",
    "test:browser": "npm run build && playwright test",
    "test:quality": "npm run build && npm run audit:quality && node scripts/run-priority-one-quality.mjs && node scripts/audit-product-quality.mjs --record-passed"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "docx": "^9.7.1",
    "docx-preview": "^0.4.0",
    "fflate": "^0.8.2",
    "firebase": "^12.15.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.23.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "pptxgenjs": "^4.0.1",
    "qpdf-run": "0.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router-dom": "^7.18.1",
    "tesseract.js": "^7.0.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.1",
    "eslint": "9.17.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
