{
  "name": "pdf-editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/generate-tool-sitemap.mjs && vite build && node scripts/prerender-public-routes.mjs && node scripts/prepare-sites-build.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "typecheck": "tsc --project jsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run build && node --test tests/e2e/*.test.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "fflate": "^0.8.2",
    "firebase": "^12.15.0",
    "lucide-react": "^1.23.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "qpdf-run": "0.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router-dom": "^7.18.1",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/node": "^24.10.1",
    "eslint": "9.17.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
