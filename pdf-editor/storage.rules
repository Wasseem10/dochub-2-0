rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId}/documents/{documentId}/{fileName} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /shares/{userId}/{token}/document.pdf {
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 26214400
        && request.resource.contentType == "application/pdf"
        && request.resource.metadata.ownerId == userId
        && request.resource.metadata.shareToken == token;
      allow read: if firestore.get(/databases/(default)/documents/shareLinks/$(token)).data.ownerId == userId
        && firestore.get(/databases/(default)/documents/shareLinks/$(token)).data.status == "active"
        && firestore.get(/databases/(default)/documents/shareLinks/$(token)).data.expiresAt > request.time;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
